{
  "name": "prompt-for-codex-medical-knowledge-base",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node scripts/dev-free-port.mjs",
    "ensure": "node scripts/ensure-local-server.mjs",
    "build": "next build",
    "start": "node scripts/dev-free-port.mjs start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:visual": "playwright test --config=playwright.visual.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "worker": "tsx worker/index.ts",
    "worker:once": "tsx worker/index.ts --once",
    "import:docs": "tsx scripts/import-documents.ts",
    "enrich:documents": "tsx scripts/enrich-documents.ts",
    "tags:backfill": "tsx scripts/backfill-document-tags.ts",
    "index:backfill": "tsx scripts/backfill-smart-index.ts",
    "check:supabase-project": "tsx scripts/check-supabase-project.ts",
    "check:indexing": "tsx scripts/check-indexing.ts",
    "promote:query-misses": "tsx scripts/promote-query-misses.ts",
    "eval:rag": "tsx scripts/eval-rag.ts",
    "eval:retrieval": "tsx scripts/eval-retrieval.ts",
    "eval:search": "tsx scripts/eval-search.ts",
    "eval:search:api": "tsx scripts/eval-search-api.ts",
    "tune:search-weights": "tsx scripts/tune-search-weights.ts",
    "cleanup:storage": "tsx scripts/cleanup-storage.ts",
    "purge:query-logs": "tsx scripts/purge-query-logs.ts",
    "audit:tables": "tsx scripts/audit-tables.ts",
    "samples": "tsx scripts/generate-sample-documents.ts",
    "samples:check": "tsx scripts/check-sample-extraction.ts"
  },
  "dependencies": {
    "@next/env": "^16.2.7",
    "@supabase/supabase-js": "^2.107.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227",
    "pdfkit": "^0.19.0",
    "postcss": "^8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
